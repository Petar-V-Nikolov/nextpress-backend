# Application
# Product name (API title, metrics)
APP_NAME=NextPressKit
APP_ENV=local
APP_PORT=9090

# Public hostname (nginx, mkcert, deploy). Local example: myapi.local + /etc/hosts.
NEXTPRESS_PUBLIC_HOST=

# Service identity (logs, systemd, nginx, dev PID/log under .tmp/, local SSL dir under ~/.local/share/).
APP_LOG_IDENTIFIER=nextpresskit-backend
APP_SERVICE_UNIT=nextpresskit-backend
APP_DEV_RUNTIME_BASENAME=nextpresskit
APP_LOCAL_SSL_SUBDIR=nextpresskit-ssl

# API path prefix; empty = unversioned. Example: /v1
API_BASE_PATH=

# Kit modules (comma-separated ids). Empty = compile-time default from internal/appregistry.
# Valid ids: user, rbac, auth, taxonomy, media, posts, pages. Implicit deps are added (e.g. auth -> user+rbac; content modules -> user+rbac+auth; posts -> taxonomy+media).
MODULES=

# CORS: comma-separated origins, no trailing slash. Needed for credentialed requests; unset = wildcard (no credentials).
CORS_ORIGINS=

# Database
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nextpresskit
DB_USER=postgres
DB_PASSWORD=secret
DB_SSLMODE=disable

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# cookie | header (default cookie)
JWT_AUTH_SOURCE=cookie

# Used when JWT_AUTH_SOURCE=cookie
JWT_ACCESS_COOKIE_NAME=access_token
JWT_REFRESH_COOKIE_NAME=refresh_token

# Cookie flags (SameSite none + Secure typical for cross-site prod)
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=none
JWT_COOKIE_PATH=/
JWT_COOKIE_DOMAIN=

# RBAC
# Enables POST /admin/bootstrap/claim-admin once
RBAC_BOOTSTRAP_ENABLED=false

# make seed
SEED_SUPERADMIN_EMAIL=superadmin@nextpresskit.local
SEED_SUPERADMIN_PASSWORD=SuperAdmin123!

# Media
MEDIA_STORAGE_DIR=storage/uploads
MEDIA_PUBLIC_BASE_URL=/uploads
MEDIA_MAX_UPLOAD_BYTES=10485760

# Rate limit (in-memory per instance; optional Redis)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_MAX_PER_MINUTE=120
RATE_LIMIT_AUTH_MAX_PER_MINUTE=30
RATE_LIMIT_ADMIN_MAX_PER_MINUTE=60
RATE_LIMIT_REDIS_ENABLED=false
RATE_LIMIT_REDIS_ADDR=
RATE_LIMIT_REDIS_PASSWORD=
RATE_LIMIT_REDIS_DB=0
RATE_LIMIT_REDIS_PREFIX=nextpresskit:ratelimit

# Elasticsearch (optional search; Postgres is source of truth)
ELASTICSEARCH_ENABLED=false
# Comma-separated; e.g. http://localhost:9200
ELASTICSEARCH_URLS=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=nextpresskit
# Dev TLS only
ELASTICSEARCH_INSECURE_SKIP_VERIFY=false
# Create index on startup if missing (default true for local/dev)
ELASTICSEARCH_AUTO_CREATE_INDEX=

# Optional: CERTBOT_EMAIL for deploy apply-nginx --letsencrypt (non-interactive)
# CERTBOT_EMAIL=you@example.com
