#!/usr/bin/env bash
# NextPressKit — cross-platform dev entry (macOS / Linux / Git Bash on Windows).
# Native Windows PowerShell: use scripts/nextpress.ps1
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
export NP_ROOT="$ROOT"
export CGO_ENABLED="${CGO_ENABLED:-0}"

VERSION="$(git describe --tags --always --dirty 2>/dev/null || echo dev)"

usage() {
  cat <<'EOF'
NextPressKit dev CLI (Linux / macOS / Git Bash). On Windows use: .\scripts\nextpress.ps1

Commands:
  help              Show this help
  install           go mod download; create .env from .env.example if missing
  tidy              go mod tidy
  deps              go mod download only
  build             Build bin/server only
  build-all         Build bin/server, bin/migrate, bin/seed
  setup             install + build-all + migrate-up + seed; from a TTY also runs
                    scripts/setup-local-https.sh (install mkcert if needed, SANs + Nginx on Linux). Skip: SKIP_SETUP_LOCAL_HTTPS=1
  migrate-up        Apply migrations
  migrate-down      Roll back one migration
  migrate-version   Show migration version
  migrate-steps N   Apply or roll back N steps (MIGRATE_CMD=up|down, default up)
  migrate-drop      Drop all tables (interactive)
  db-fresh            migrate-drop then migrate-up (destructive)
  seed              Run seeders
  run               Foreground API (go run)
  start             Background API + .tmp/nextpress-api.pid
  stop              Stop background API + soft-clear same-repo listeners
  deploy              Interactive Nginx/TLS wizard (bash scripts/deploy)
  deploy-apply-nginx  Non-interactive: write Nginx config + install on Linux (see scripts/deploy apply-nginx --help)
  checks            CI-style: test, vet, integration, OpenAPI, govulncheck
  test | test-coverage | test-integration
  security-check | graphql | clean

Examples:
  ./scripts/nextpress setup
  ./scripts/nextpress run
  MIGRATE_CMD=down ./scripts/nextpress migrate-steps 2
EOF
}

ensure_go() {
  command -v go >/dev/null 2>&1 || {
    echo "Go is not installed or not on PATH." >&2
    exit 1
  }
}

cmd="${1:-help}"
[[ "$cmd" == "-h" || "$cmd" == "--help" ]] && cmd=help

case "$cmd" in
help)
  usage
  ;;
install)
  ensure_go
  go mod download
  if [[ ! -f "$ROOT/.env" ]]; then
    cp "$ROOT/.env.example" "$ROOT/.env"
    echo "Created .env from .env.example — edit DB_* and JWT_SECRET before migrate/seed."
  else
    echo ".env already exists."
  fi
  ;;
tidy)
  ensure_go
  go mod tidy
  ;;
deps)
  ensure_go
  go mod download
  ;;
build)
  ensure_go
  mkdir -p bin
  go build -ldflags "-X main.version=$VERSION" -o bin/server ./cmd/api
  echo "Built bin/server"
  ;;
build-all)
  ensure_go
  mkdir -p bin
  go build -ldflags "-X main.version=$VERSION" -o bin/server ./cmd/api
  go build -o bin/migrate ./cmd/migrate
  go build -o bin/seed ./cmd/seed
  echo "Built bin/server, bin/migrate, bin/seed"
  ;;
setup)
  "$0" install
  "$0" build-all
  "$0" migrate-up
  "$0" seed
  uname_s="$(uname -s 2>/dev/null || echo unknown)"
  case "$uname_s" in
    MINGW*|MSYS*|CYGWIN*)
      ;;
    *)
      if [[ -t 0 ]] && [[ "${SKIP_SETUP_LOCAL_HTTPS:-}" != "1" ]]; then
        bash "$ROOT/scripts/setup-local-https.sh" || true
      fi
      ;;
  esac
  echo "Setup complete. Run: ./scripts/nextpress run   (or: make run)"
  ;;
migrate-up)
  ensure_go
  go run ./cmd/migrate -command=up
  ;;
migrate-down)
  ensure_go
  go run ./cmd/migrate -command=down -steps=1
  ;;
migrate-version)
  ensure_go
  go run ./cmd/migrate -command=version
  ;;
migrate-steps)
  ensure_go
  n="${2:?usage: nextpress migrate-steps <N>}"
  mc="${MIGRATE_CMD:-up}"
  go run ./cmd/migrate -command="$mc" -steps="$n"
  ;;
migrate-drop)
  ensure_go
  echo "WARNING: This drops all tables in the configured database."
  read -r -p "Type y to continue: " confirm
  [[ "${confirm:-N}" == "y" ]] || exit 1
  go run ./cmd/migrate -command=drop
  ;;
db-fresh)
  "$0" migrate-drop
  "$0" migrate-up
  ;;
seed)
  ensure_go
  go run ./cmd/seed
  ;;
run)
  ensure_go
  exec bash "$ROOT/scripts/dev-run.sh"
  ;;
start)
  ensure_go
  bash "$ROOT/scripts/dev-start.sh"
  ;;
stop)
  bash "$ROOT/scripts/dev-stop.sh"
  ;;
deploy)
  exec bash "$ROOT/scripts/deploy"
  ;;
deploy-apply-nginx)
  shift
  exec bash "$ROOT/scripts/deploy" apply-nginx "$@"
  ;;
checks)
  ensure_go
  go test ./...
  go vet ./...
  go test -tags=integration -v ./internal/platform/database
  go run github.com/getkin/kin-openapi/cmd/validate@latest "$ROOT/docs/openapi.yaml"
  go run golang.org/x/vuln/cmd/govulncheck@latest ./...
  ;;
test)
  ensure_go
  exec go test -v ./...
  ;;
test-coverage)
  ensure_go
  exec go test -cover ./...
  ;;
test-integration)
  ensure_go
  exec go test -tags=integration -v ./internal/platform/database
  ;;
security-check)
  ensure_go
  exec go run golang.org/x/vuln/cmd/govulncheck@latest ./...
  ;;
graphql)
  ensure_go
  exec go run github.com/99designs/gqlgen generate
  ;;
clean)
  rm -rf bin/
  go clean
  ;;
*)
  echo "Unknown command: $cmd" >&2
  usage >&2
  exit 1
  ;;
esac
